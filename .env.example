# ─────────────────────────────────────────────────────
# BC Registries — Test Environment Credentials
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────

# IDIR credentials (BC Gov employee test account)
IDIR_USERNAME=your_idir_username
IDIR_PASSWORD=your_idir_password

# Optional: used by some business flow tests
TEST_ACCOUNT_ID=
TEST_BUSINESS_INC_NUMBER=BC1234567
TEST_SEARCH_TERM=TEST

# For Claude self-healing (optional)
ANTHROPIC_API_KEY=sk-ant-...
